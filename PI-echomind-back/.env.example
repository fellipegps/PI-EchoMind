# ─── EchoMind – Variáveis de Ambiente ─────────────────────────────────────────
# Copie este arquivo para .env e ajuste os valores antes de rodar o docker compose.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=echomind
POSTGRES_PASSWORD=echomind_senha_forte_aqui
POSTGRES_DB=echomind

# ── Groq (LLM na nuvem) ───────────────────────────────────────────────────────
# Obtenha sua chave gratuita em: https://console.groq.com
# OBRIGATÓRIO — o backend não sobe sem esta chave.
GROQ_API_KEY=gsk_SUBSTITUA_PELA_SUA_CHAVE_AQUI
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings locais ─────────────────────────────────────────────────────────
# Gerados dentro do container via sentence-transformers (sem servidor externo).
# Troque apenas se recriar o banco do zero (dimensão deve bater com EMBEDDING_DIM).
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# ── RAG ────────────────────────────────────────────────────────────────────────
# Dimensão do vetor de embedding.
# paraphrase-multilingual-mpnet-base-v2 = 768 dims (padrão atual)
# NÃO mude este valor sem recriar o banco do zero (DROP volume + docker compose up)
EMBEDDING_DIM=768

# Threshold de DISTÂNCIA coseno (0=idêntico, 2=oposto).
# 0.70 = tolerante para banco pequeno. Diminua para 0.50 com banco populado.
SIMILARITY_THRESHOLD=0.70

# Número de chunks recuperados por query
TOP_K_DOCS=3
